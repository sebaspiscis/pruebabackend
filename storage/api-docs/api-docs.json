        "/api/productos": {
            "get": {
                "tags": [
                    "Productos"
                ],
                "summary": "Listar todos los productos",
                "operationId": "6a50fdaffa42b3cfe730067edc3b8415",
                "responses": {
                    "200": {
                        "description": "Lista de productos",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": true
                                        },
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "properties": {
                                                    "id": {
                                                        "type": "string",
                                                        "format": "uuid"
                                                    },
                                                    "name": {
                                                        "type": "string",
                                                        "example": "Laptop"
                                                    },
                                                    "description": {
                                                        "type": "string",
                                                        "example": "Laptop gamer"
                                                    },
                                                    "price": {
                                                        "type": "number",
                                                        "example": 999.99
                                                    },
                                                    "stock": {
                                                        "type": "integer",
                                                        "example": 10
                                                    },
                                                    "categoria_id": {
                                                        "type": "string",
                                                        "format": "uuid"
                                                    }
                                                },
                                                "type": "object"
                                            }
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "500": {
                        "description": "Error interno"
                    }
                }
            },
            "post": {
                "tags": [
                    "Productos"
                ],
                "summary": "Crear un producto",
                "operationId": "8151ada2fedbf202e75db917f2bb1752",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "name",
                                    "description",
                                    "price",
                                    "stock",
                                    "categoria_id"
                                ],
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "example": "Laptop",
                                        "maxLength": 50
                                    },
                                    "description": {
                                        "type": "string",
                                        "example": "Laptop gamer",
                                        "maxLength": 250
                                    },
                                    "price": {
                                        "type": "number",
                                        "example": 999.99
                                    },
                                    "stock": {
                                        "type": "integer",
                                        "example": 10
                                    },
                                    "categoria_id": {
                                        "type": "string",
                                        "format": "uuid",
                                        "example": "uuid-de-la-categoria"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Producto creado correctamente"
                    },
                    "500": {
                        "description": "Error interno"
                    }
                }
            }
